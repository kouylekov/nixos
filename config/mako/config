# Mako notification daemon config - Monochromatic theme

max-visible=5
sort=-time
layer=overlay
anchor=top-right

font=JetBrainsMono Nerd Font 11
background-color=#141414ee
text-color=#e0e0e0
border-color=#ffffff66
border-size=2
border-radius=12
margin=8
padding=12
default-timeout=5000
ignore-timeout=0

[urgency=low]
border-color=#808080
default-timeout=3000

[urgency=normal]
border-color=#c0c0c0
default-timeout=5000

[urgency=critical]
border-color=#ffffff
default-timeout=0
