# Font configuration
font-family = "JetBrainsMono Nerd Font"
font-size = 12
font-thicken = true

# Window appearance
window-padding-x = 8
window-padding-y = 8
background-opacity = 0.95
background-blur-radius = 20

# Grayscale color scheme (matching waybar theme)
background = 141414
foreground = e0e0e0

# Cursor
cursor-color = ffffff
cursor-style = block
cursor-style-blink = false

# Grayscale palette
palette = 0=#1a1a1a
palette = 1=#8a8a8a
palette = 2=#9a9a9a
palette = 3=#a8a8a8
palette = 4=#b0b0b0
palette = 5=#bebebe
palette = 6=#c8c8c8
palette = 7=#d0d0d0
palette = 8=#404040
palette = 9=#9a9a9a
palette = 10=#ababab
palette = 11=#b8b8b8
palette = 12=#c0c0c0
palette = 13=#cacaca
palette = 14=#d8d8d8
palette = 15=#e8e8e8

# Shell integration
shell-integration = bash
shell-integration-features = cursor,sudo,title

# Mouse behavior
mouse-hide-while-typing = true
copy-on-select = true

# Better text rendering
adjust-cell-height = 10%
adjust-underline-position = 15%
adjust-underline-thickness = 150%

# Window behavior
window-theme = dark
confirm-close-surface = false
quit-after-last-window-closed = true

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Performance
unfocused-split-opacity = 0.8

