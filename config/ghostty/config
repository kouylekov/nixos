# Font configuration
font-family = "JetBrainsMono Nerd Font"
font-size = 12
font-thicken = true

# Window appearance
window-padding-x = 8
window-padding-y = 8
background-opacity = 0.95
background-blur-radius = 20

# TokyoNight color scheme
background = 1a1b26
foreground = c0caf5

# Cursor
cursor-color = c0caf5
cursor-style = block
cursor-style-blink = false

# TokyoNight palette
palette = 0=#15161e
palette = 1=#f7768e
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#7aa2f7
palette = 5=#bb9af7
palette = 6=#7dcfff
palette = 7=#a9b1d6
palette = 8=#414868
palette = 9=#f7768e
palette = 10=#9ece6a
palette = 11=#e0af68
palette = 12=#7aa2f7
palette = 13=#bb9af7
palette = 14=#7dcfff
palette = 15=#c0caf5

# Shell integration
shell-integration = bash
shell-integration-features = cursor,sudo,title

# Mouse behavior
mouse-hide-while-typing = true
copy-on-select = true

# Better text rendering
adjust-cell-height = 10%
adjust-underline-position = 15%
adjust-underline-thickness = 150%

# Window behavior
window-theme = dark
confirm-close-surface = false
quit-after-last-window-closed = true

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# Performance
unfocused-split-opacity = 0.8

